{
  "manifest_version": 3,
  "name": "Financial News Sentiment Analyzer",
  "description": "Analyze financial news sentiment with AI-powered insights",
  "version": "1.0.0",
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Sentiment Analyzer"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://api.codesmart.app/*",
    "https://query1.finance.yahoo.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/overlay.css"]
    }
  ],
  "commands": {
    "quick-analyze": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Quick analyze with first portfolio"
    }
  }
}
